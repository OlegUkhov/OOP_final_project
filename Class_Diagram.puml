@startuml Class_Diagram
title University Research System — Class Diagram

skinparam classBackgroundColor #EEF4FF
skinparam classBorderColor #4A90D9
skinparam arrowColor #2C5F8A
skinparam stereotypeCBackgroundColor #D6E8FF
skinparam packageStyle rectangle
skinparam linetype ortho

' ═══════════════════════════════════════════
'  ENUMERATIONS
' ═══════════════════════════════════════════
enum TeacherPosition {
  TUTOR
  LECTOR
  SENIOR_LECTOR
  PROFESSOR
}

enum ManagerType {
  OR
  DEPARTMENT
}

enum CourseType {
  MAJOR
  MINOR
  FREE_ELECTIVE
}

enum LessonType {
  LECTURE
  PRACTICE
}

enum Language {
  KZ
  EN
  RU
}

enum ComplaintUrgency {
  LOW
  MEDIUM
  HIGH
}

enum RequestStatus {
  VIEWED
  ACCEPTED
  REJECTED
  DONE
}

enum CitationFormat {
  PLAIN_TEXT
  BIBTEX
}

enum MessageType {
  REGULAR
  REQUEST
}

' ═══════════════════════════════════════════
'  EXCEPTIONS
' ═══════════════════════════════════════════
class LowHIndexException extends Exception {
  + LowHIndexException(message: String)
}

class NotResearcherException extends Exception {
  + NotResearcherException(message: String)
}

class CourseOverloadException extends Exception {
  + CourseOverloadException(message: String)
}

class CourseFailLimitException extends Exception {
  + CourseFailLimitException(message: String)
}

' ═══════════════════════════════════════════
'  USER HIERARCHY
' ═══════════════════════════════════════════
abstract class User {
  # id: String
  # firstName: String
  # lastName: String
  # email: String
  # password: String
  # language: Language
  --
  + {static} authenticate(email, pwd): User
  + checkPassword(pwd): boolean
  + logout(): void
  + onNewsReceived(n: News): void
  + toString(): String
  + equals(o: Object): boolean
  + hashCode(): int
}

class Student extends User {
  - studentId: String
  - gpa: double
  - failCount: int
  - researcher: boolean
  --
  + registerForCourse(c: Course): void
  + submitRequest(description: String): void
  + viewCourses(): List<Course>
  + viewTeachersForCourse(c: Course): List<Teacher>
  + viewMarks(): List<Mark>
  + getTranscript(): String
  + rateTeacher(t: Teacher, rating: int): void
  + joinOrganization(org: StudentOrganization): void
  + getTotalCredits(): int
  + viewAllNews(): void
  + toString(): String
}

class GraduateStudent extends Student {
  - supervisor: Researcher
  --
  + setSupervisor(r: Researcher): void
  + publishDiplomaPaper(p: ResearchPaper): void
  + getDiplomaPapers(): List<ResearchPaper>
}

abstract class Employee extends User {
  # employeeId: String
  # salary: double
  # department: String
  --
  + sendMessage(to: Employee, text: String): void
  + viewRequests(): List<Request>
}

class Teacher extends Employee {
  - position: TeacherPosition
  - rating: double
  - researcher: boolean
  --
  + viewCourses(): List<Course>
  + manageCourse(c: Course): void
  + putMark(s: Student, c: Course, m: Mark): void
  + sendComplaint(s: Student, text: String, urgency: ComplaintUrgency): Complaint
  + viewStudentsInfo(): void
  + getPosition(): TeacherPosition
  + isResearcher(): boolean
  + toString(): String
}

class Manager extends Employee {
  - managerType: ManagerType
  --
  + assignCourse(t: Teacher, c: Course): void
  + approveRegistration(s: Student, c: Course): void
  + createStatisticalReport(): String
  + manageNews(n: News): void
  + viewEmployeeRequests(): List<Request>
  + getStudentsSortedByGpa(): List<Student>
  + getStudentsSortedByName(): List<Student>
  + publishNews(title, content, topic): void
  + generateTopCitedResearcherNews(): void
  + addCourseForRegistration(c: Course, major: String, year: int): void
}

class Admin extends Employee {
  --
  + addUser(u: User): void
  + removeUser(id: String): void
  + updateUser(u: User): void
  + viewLogFiles(): List<Log>
}

class TechSupportSpecialist extends Employee {
  --
  + viewNewRequests(): List<Request>
  + acceptRequest(r: Request): void
  + rejectRequest(r: Request): void
  + markAsDone(r: Request): void
}

' ═══════════════════════════════════════════
'  RESEARCHER  (Decorator Pattern)
' ═══════════════════════════════════════════
interface Researcher {
  + publishPaper(p: ResearchPaper): void
  + calculateHIndex(): int
  + leadProject(rp: ResearchProject): void
  + printPapers(c: Comparator<ResearchPaper>): void
  + getPapers(): List<ResearchPaper>
}

abstract class ResearcherDecorator implements Researcher {
  # researcher: Researcher
  --
  + ResearcherDecorator(r: Researcher)
  + publishPaper(p: ResearchPaper): void
  + calculateHIndex(): int
  + leadProject(rp: ResearchProject): void
  + printPapers(c: Comparator<ResearchPaper>): void
  + getPapers(): List<ResearchPaper>
}

class TeacherResearcher extends ResearcherDecorator {
  - teacher: Teacher
  --
  + TeacherResearcher(t: Teacher)
  + publishPaper(p: ResearchPaper): void
  + calculateHIndex(): int
}

class StudentResearcher extends ResearcherDecorator {
  - student: Student
  --
  + StudentResearcher(s: Student)
  + publishPaper(p: ResearchPaper): void
  + calculateHIndex(): int
}

' ═══════════════════════════════════════════
'  RESEARCH ENTITIES
' ═══════════════════════════════════════════
class ResearchPaper {
  - paperId: String
  - title: String
  - authors: List<String>
  - journal: String
  - citations: int
  - pages: int
  - datePublished: Date
  - doi: String
  - ownerId: String
  --
  + getCitation(f: CitationFormat): String
  + getCitations(): int
  + getPages(): int
  + getDatePublished(): Date
  + setOwnerId(id: String): void
  + toString(): String
  + equals(o: Object): boolean
  + hashCode(): int
}

class ResearchProject {
  - topic: String
  - participants: List<Researcher>
  - papers: List<ResearchPaper>
  --
  + addParticipant(r: Researcher): void
  + removeParticipant(r: Researcher): void
  + addPaper(p: ResearchPaper): void
  + getParticipants(): List<Researcher>
}

' ═══════════════════════════════════════════
'  COMPARATORS
' ═══════════════════════════════════════════
interface "Comparator<ResearchPaper>" as CmpRP {
  + compare(a: ResearchPaper, b: ResearchPaper): int
}

class DateComparator implements CmpRP {
  + compare(a: ResearchPaper, b: ResearchPaper): int
}

class CitationComparator implements CmpRP {
  + compare(a: ResearchPaper, b: ResearchPaper): int
}

class LengthComparator implements CmpRP {
  + compare(a: ResearchPaper, b: ResearchPaper): int
}

' ═══════════════════════════════════════════
'  COURSE & LESSON
' ═══════════════════════════════════════════
class Course {
  - courseId: String
  - name: String
  - credits: int
  - courseType: CourseType
  - major: String
  - studyYear: int
  - teachers: List<Teacher>
  - lessons: List<Lesson>
  --
  + addTeacher(t: Teacher): void
  + addLesson(l: Lesson): void
  + getLessons(): List<Lesson>
  + getTeachers(): List<Teacher>
  + getCredits(): int
  + setMajor(major: String): void
  + setStudyYear(year: int): void
  + toString(): String
}

class Lesson {
  - lessonId: String
  - topic: String
  - lessonType: LessonType
  --
  + getLessonType(): LessonType
  + toString(): String
}

' ═══════════════════════════════════════════
'  MARK
' ═══════════════════════════════════════════
class Mark {
  - firstAttestation: double
  - secondAttestation: double
  - finalExam: double
  - student: Student
  - course: Course
  --
  + getTotalScore(): double
  + getLetterGrade(): String
  + toString(): String
}

' ═══════════════════════════════════════════
'  COMPLAINT
' ═══════════════════════════════════════════
class Complaint {
  - complaintId: String
  - student: Student
  - text: String
  - urgency: ComplaintUrgency
  - date: Date
  --
  + getUrgency(): ComplaintUrgency
  + toString(): String
}

' ═══════════════════════════════════════════
'  STUDENT ORGANIZATION
' ═══════════════════════════════════════════
class StudentOrganization {
  - name: String
  - head: Student
  - members: List<Student>
  --
  + addMember(s: Student): void
  + removeMember(s: Student): void
  + setHead(s: Student): void
  + getMembers(): List<Student>
}

' ═══════════════════════════════════════════
'  NEWS & MESSAGE
' ═══════════════════════════════════════════
class News {
  - newsId: String
  - title: String
  - content: String
  - topic: String
  - isPinned: boolean
  - date: Date
  - comments: List<String>
  --
  + addComment(c: String): void
  + pin(): void
  + getTitle(): String
  + getTopic(): String
  + toString(): String
}

class Message {
  # messageId: String
  # sender: User
  # receiver: User
  # content: String
  # date: Date
  # type: MessageType
  --
  + getContent(): String
  + getType(): MessageType
  + isRequest(): boolean
  + toString(): String
}

class Request extends Message {
  - status: RequestStatus
  --
  + getStatus(): RequestStatus
  + setStatus(s: RequestStatus): void
  + toString(): String
}

class Enrollment {
  - studentId: String
  - courseId: String
}

' ═══════════════════════════════════════════
'  LOG (used by Admin)
' ═══════════════════════════════════════════
class Log {
  - logId: String
  - userId: String
  - action: String
  - timestamp: Date
  --
  + toString(): String
}

' ═══════════════════════════════════════════
'  OBSERVER PATTERN — Journal
' ═══════════════════════════════════════════
interface Observer {
  + update(paper: ResearchPaper): void
}

interface Observable {
  + subscribe(o: Observer): void
  + unsubscribe(o: Observer): void
  + notifyObservers(paper: ResearchPaper): void
}

class Journal implements Observable {
  - name: String
  - papers: List<ResearchPaper>
  - subscribers: List<Observer>
  --
  + publishPaper(p: ResearchPaper): void
  + subscribe(o: Observer): void
  + unsubscribe(o: Observer): void
  + notifyObservers(paper: ResearchPaper): void
  + getPapers(): List<ResearchPaper>
}

User .up.|> Observer : <<implements>>

' ═══════════════════════════════════════════
'  SINGLETON — DataStorage
' ═══════════════════════════════════════════
class DataStorage {
  - {static} instance: DataStorage
  - users: List<User>
  - courses: List<Course>
  - enrollments: List<Enrollment>
  - marks: List<Mark>
  - papers: List<ResearchPaper>
  - projects: List<ResearchProject>
  - journals: List<Journal>
  - logs: List<Log>
  - news: List<News>
  - messages: List<Message>
  - complaints: List<Complaint>
  - organizations: List<StudentOrganization>
  --
  - DataStorage()
  + {static} getInstance(): DataStorage
  + addUser(u: User): void
  + removeUser(id: String): void
  + enrollStudent(s: Student, c: Course): void
  + addMark(m: Mark): void
  + addMessage(m: Message): void
  + addNews(n: News): void
  + publishNews(n: News): void
  + getRequests(): List<Request>
  + getAllResearchers(): List<Researcher>
  + getTopCitedResearcher(): Researcher
  + printAllResearchersPapers(c: Comparator): void
  + saveData(): void
  + loadData(): void
  note: PrintWriter / Scanner, text files in data/
}

' ═══════════════════════════════════════════
'  RELATIONSHIPS
' ═══════════════════════════════════════════

' Inheritance

' Decorator wraps
TeacherResearcher  -->  Teacher    : wraps
StudentResearcher  -->  Student    : wraps

' GraduateStudent supervisor
GraduateStudent "0..*" --> "1" Researcher : supervisor

' Course — Teacher (association)
Course "0..*" --> "1..*" Teacher : taught by

' Enrollment (stored in DataStorage)
Enrollment --> Student : studentId
Enrollment --> Course : courseId

' Composition: Course -> Lesson
Course "1" *-- "1..*" Lesson : contains

' Mark
Mark "0..*" --> "1" Student  : belongs to
Mark "0..*" --> "1" Course   : for

' Complaint
Complaint "0..*" --> "1" Student : about

' Student Organization
StudentOrganization "0..*" --> "1"    Student        : head
StudentOrganization "0..*" --> "0..*" Student        : members

' Research
ResearchProject "0..*" --> "0..*" Researcher    : participants
ResearchProject "1"    *-- "0..*" ResearchPaper : published papers

' Teacher's position enum
Teacher --> TeacherPosition

' Course type
Course --> CourseType

' Lesson type
Lesson --> LessonType

' Mark — double attestation (already fields)

' Message hierarchy
Message --> MessageType
Request --> RequestStatus
Message "0..*" --> "1" User : sender
Message "0..*" --> "0..1" User : receiver

' DataStorage aggregates everything (Singleton)
DataStorage o-- User
DataStorage o-- Course
DataStorage o-- Enrollment
DataStorage o-- Mark
DataStorage o-- Message
DataStorage o-- Complaint
DataStorage o-- StudentOrganization
DataStorage o-- Journal
DataStorage o-- Log
DataStorage o-- News
DataStorage o-- ResearchPaper
DataStorage o-- ResearchProject

@enduml
